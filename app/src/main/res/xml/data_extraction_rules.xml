<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
	<cloud-backup>
		<!-- 変更理由: cloud backupではDBとKeystore依存パスワードを直接抽出せず、BackupAgentの選別済みデータに限定する。 -->
		<exclude
			domain="database"
			path="connectbot.db" />
		<exclude
			domain="database"
			path="connectbot.db-wal" />
		<exclude
			domain="database"
			path="connectbot.db-shm" />
		<exclude
			domain="database"
			path="connectbot.db-journal" />
		<exclude
			domain="database"
			path="connectbot_backup_temp.db" />
		<exclude
			domain="database"
			path="connectbot_backup_temp.db-wal" />
		<exclude
			domain="database"
			path="connectbot_backup_temp.db-shm" />
		<exclude
			domain="database"
			path="connectbot_backup_temp.db-journal" />
		<exclude
			domain="database"
			path="connectbot.db.restore" />
		<exclude
			domain="database"
			path="connectbot.db.restore-wal" />
		<exclude
			domain="database"
			path="connectbot.db.restore-shm" />
		<exclude
			domain="database"
			path="connectbot.db.restore-journal" />
		<exclude
			domain="database"
			path="connectbot.db.pre-restore" />
		<exclude
			domain="database"
			path="connectbot.db.pre-restore-wal" />
		<exclude
			domain="database"
			path="connectbot.db.pre-restore-shm" />
		<exclude
			domain="database"
			path="connectbot.db.pre-restore-journal" />
		<exclude
			domain="sharedpref"
			path="secure_host_passwords.xml" />
	</cloud-backup>
	<device-transfer>
		<!-- 変更理由: 端末移行でも秘密鍵・保存パスワードを含むDBファイルを丸ごと移さない。 -->
		<exclude
			domain="database"
			path="connectbot.db" />
		<exclude
			domain="database"
			path="connectbot.db-wal" />
		<exclude
			domain="database"
			path="connectbot.db-shm" />
		<exclude
			domain="database"
			path="connectbot.db-journal" />
		<exclude
			domain="database"
			path="connectbot_backup_temp.db" />
		<exclude
			domain="database"
			path="connectbot_backup_temp.db-wal" />
		<exclude
			domain="database"
			path="connectbot_backup_temp.db-shm" />
		<exclude
			domain="database"
			path="connectbot_backup_temp.db-journal" />
		<exclude
			domain="database"
			path="connectbot.db.restore" />
		<exclude
			domain="database"
			path="connectbot.db.restore-wal" />
		<exclude
			domain="database"
			path="connectbot.db.restore-shm" />
		<exclude
			domain="database"
			path="connectbot.db.restore-journal" />
		<exclude
			domain="database"
			path="connectbot.db.pre-restore" />
		<exclude
			domain="database"
			path="connectbot.db.pre-restore-wal" />
		<exclude
			domain="database"
			path="connectbot.db.pre-restore-shm" />
		<exclude
			domain="database"
			path="connectbot.db.pre-restore-journal" />
		<exclude
			domain="sharedpref"
			path="secure_host_passwords.xml" />
	</device-transfer>
</data-extraction-rules>
